{
  "name": "siteline-aws-cloudfront",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready AWS Lambda@Edge interceptor for CloudFront using @siteline/core",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup --config config/tsup.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --config config/eslint.config.mjs . --max-warnings=0",
    "format": "prettier --config config/prettier.config.cjs --write .",
    "test": "vitest run",
    "package": "npm run build && bash scripts/package.sh",
    "deploy": "bash scripts/deploy.sh",
    "attach:cloudfront": "bash scripts/attach-cloudfront.sh",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@siteline/core": "^1.0.1",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^22.19.11",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
