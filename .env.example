# App metadata
APP_NAME=siteline-cloudfront-edge

# Siteline SDK settings
SITELINE_WEBSITE_KEY=siteline_secret_replace_with_real_key
SITELINE_ENDPOINT=https://siteline.ai/v1/intake/pageview
SITELINE_DEBUG=false

# Deployment defaults (used by scripts/deploy.sh and scripts/attach-cloudfront.sh)
AWS_REGION=us-east-1
AWS_PROFILE=default
LAMBDA_FUNCTION_NAME=siteline-cloudfront-viewer-request
LAMBDA_ROLE_NAME=siteline-cloudfront-edge-role
LAMBDA_RUNTIME=nodejs18.x
DISTRIBUTION_ID=E0000000000000
# Attach twice using scripts/attach-cloudfront.sh:
# 1) EVENT_TYPE=viewer-request
# 2) EVENT_TYPE=viewer-response
EVENT_TYPE=viewer-request
INCLUDE_BODY=false
