# AWS credentials and execution
AWS_REGION=us-east-1
AWS_PROFILE=default
AUTO_APPROVE=false

# App and Siteline runtime settings
APP_NAME=siteline-cloudfront-s3-processor
SITELINE_WEBSITE_KEY=siteline_secret_replace_with_real_key
SITELINE_ENDPOINT=https://siteline.ai/v1/intake/pageview
SITELINE_DEBUG=false

# S3 / CloudFront standard logging
LOG_BUCKET_NAME=siteline-cloudfront-logs
S3_BUCKET_REGION=us-east-1

# Lambda processor
LAMBDA_FUNCTION_NAME=siteline-cloudfront-s3-processor
LAMBDA_ROLE_NAME=siteline-cloudfront-s3-processor-role
LAMBDA_RUNTIME=nodejs20.x
LAMBDA_ARCHITECTURE=x86_64
LAMBDA_TIMEOUT_SECONDS=60
LAMBDA_MEMORY_MB=256
LAMBDA_ZIP_PATH=dist/lambda-edge.zip

# EventBridge
EVENT_RULE_NAME=siteline-cloudfront-s3-log-created
EVENT_TARGET_ID=siteline-lambda-target
